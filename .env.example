# LinkedIn Autopilot v2 — Environment Variables
# Copy this file to .env and fill in your keys.

# Required: Anthropic API key for all AI generation
ANTHROPIC_API_KEY=

# Optional: Web trend scouting
SERPER_API_KEY=

# Optional: Email digest delivery
RESEND_API_KEY=

# Optional: LinkedIn auto-posting
PHANTOMBUSTER_API_KEY=
LINKEDIN_PHANTOM_ID=

# Optional: Embedding-based deduplication
OPENAI_API_KEY=

# --- Browser Automation (choose one backend) ---
BROWSER_BACKEND=airtop

# Airtop (cloud browser — recommended for production)
# Sign up at https://www.airtop.ai/
AIRTOP_API_KEY=

# Browser Use (local AI browser agent — good for development)
# Uses OPENAI_API_KEY above for the underlying LLM, or set a separate key:
BROWSER_USE_API_KEY=
